@using MySqlConnector;
@using System.Data.Common;
@using System.Text.Json;
@using System.Security.Claims

@inject NavigationManager NavigationManager
@inject ILocalStorageService localStorage
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Pages.Users.Dialogs.Reset_Password_User_Dialog> Localizer
@inject AuthenticationStateProvider AuthenticationStateProvider

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h5">
            <MudIcon Icon="@Icons.Material.Filled.LockReset" Class="mr-2" />
            @Localizer["title"]
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (String.IsNullOrEmpty(one_time_password))
        {
            <MudAlert Severity="Severity.Warning" Icon="@Icons.Material.Filled.Warning" Class="mb-3">
                @Localizer["one_time_password_text_1"]
            </MudAlert>
            
            <MudText Typo="Typo.body1" Class="mb-2">
                <strong>User:</strong> @username
            </MudText>
            
            <MudText Typo="Typo.body2" Style="color: gray;">
                The user will be required to change their password on next login.
            </MudText>
        }
        else
        {
            <MudAlert Severity="Severity.Success" Icon="@Icons.Material.Filled.CheckCircle" Class="mb-3">
                Password has been reset successfully!
            </MudAlert>
            
            <MudText Typo="Typo.body1" Class="mb-3">
                @Localizer["one_time_password_text_2"]
            </MudText>
            
            <MudTextField 
                Label="One-Time Password" 
                T="string" 
                @bind-Value="@one_time_password" 
                ReadOnly="true" 
                Variant="Variant.Filled"
                Adornment="Adornment.End"
                AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                OnAdornmentClick="Copy_Password_To_Clipboard"
                AdornmentAriaLabel="Copy to clipboard"
                FullWidth="true" />
            
            <MudText Typo="Typo.caption" Style="color: gray;" Class="mt-2">
                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" /> 
                Make sure to save this password - it cannot be recovered later.
            </MudText>
        }
    </DialogContent>

    <DialogActions>
        @if (String.IsNullOrEmpty(one_time_password))
        {
            <MudButton OnClick="Cancel" Variant="Variant.Text">
                @Localizer["cancel"]
            </MudButton>

            <MudButton 
                OnClick="Reset_Password" 
                Variant="@Variant.Filled" 
                Color="@Color.Warning"
                StartIcon="@Icons.Material.Filled.LockReset"
                Size="Size.Small"
                Disabled="@resetting">
                @if (resetting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    <span class="ml-2">Resetting...</span>
                }
                else
                {
                    @Localizer["reset_password"]
                }
            </MudButton>
        }
        else
        {
            <MudButton
                OnClick="Copy_Password_To_Clipboard"
                Variant="Variant.Text"
                Color="Color.Primary"
                Size="Size.Small"
                StartIcon="@Icons.Material.Filled.ContentCopy">
                Copy to Clipboard
            </MudButton>
            
            <MudButton
                OnClick="OK"
                Variant="@Variant.Filled"
                Size="Size.Small"
                Color="@Color.Primary">
                Close
            </MudButton>
        }
    </DialogActions>
</MudDialog>


@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public string username { get; set; }

    private string temp_username = String.Empty;
    private string one_time_password = String.Empty;
    private bool resetting = false;

    protected override async Task OnInitializedAsync()
    {
        // Get the current user from the authentication state
        var user = (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;

        // Check if user is authenticated
        if (user?.Identity is not { IsAuthenticated: true })
        {
            NavigationManager.NavigateTo("/login", true);
            return;
        }

        temp_username = username;
        Logging.Handler.Debug("/manage_users (Reset_Password_User_Dialog) -> OnInitializedAsync", "temp_username", temp_username);
    }

    private async Task Copy_Password_To_Clipboard()
    {
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;

        string credentials = $"Username: {temp_username}\nOne-Time Password: {one_time_password}";

        await JSRuntime.InvokeVoidAsync("copyToClipboard", credentials);

        Snackbar.Add("Password copied to clipboard!", Severity.Info, config => { config.ShowCloseIcon = true; });
    }

    private async Task Reset_Password()
    {
        resetting = true;
        StateHasChanged();

        Snackbar.Configuration.ShowCloseIcon = true;
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;

        bool success = false;
        MySqlConnection conn = new MySqlConnection(Configuration.MySQL.Connection_String);

        try
        {
            // Generate secure one-time password
            one_time_password = Randomizer.Handler.Generate_Password(true, 12);
            string one_time_password_hash = BCrypt.HashPassword(one_time_password);

            await conn.OpenAsync();

            // Update password and set reset flag
            string execute_query = "UPDATE accounts SET reset_password = 1, password = @one_time_password_hash WHERE username = @temp_username;";

            MySqlCommand cmd = new MySqlCommand(execute_query, conn);
            cmd.Parameters.AddWithValue("@temp_username", temp_username);
            cmd.Parameters.AddWithValue("@one_time_password_hash", one_time_password_hash);
            
            int rowsAffected = await cmd.ExecuteNonQueryAsync();

            if (rowsAffected > 0)
            {
                success = true;
                Snackbar.Add($"Password reset successfully for user: {temp_username}", Severity.Success);
                Logging.Handler.Debug("/manage_users (Reset_Password_User_Dialog)", "Password reset successful", temp_username);
            }
            else
            {
                Snackbar.Add("Failed to reset password. User not found.", Severity.Error);
                Logging.Handler.Error("/manage_users (Reset_Password_User_Dialog)", "No rows affected", temp_username);
            }
        }
        catch (Exception ex)
        {
            Logging.Handler.Error("/manage_users (Reset_Password_User_Dialog) -> Reset_Password", "Error", ex.ToString());
            Snackbar.Add("An error occurred while resetting the password.", Severity.Error);
            success = false;
        }
        finally
        {
            await conn.CloseAsync();
            resetting = false;
            StateHasChanged();
        }

        // If failed, clear the password so user can try again
        if (!success)
        {
            one_time_password = String.Empty;
        }
    }

    private void OK()
    {
        MudDialog.Close(DialogResult.Ok("success"));
    }

    private void Cancel() => MudDialog.Cancel();
}
