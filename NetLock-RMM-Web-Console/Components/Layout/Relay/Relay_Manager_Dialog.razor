    private async Task<IEnumerable<DeviceInfo>> SearchDevices(string value, CancellationToken cancellationToken)
    {
        // If no search term, return all filtered devices
        if (string.IsNullOrEmpty(value))
            return await Task.FromResult(filtered_devices.AsEnumerable());

        // Filter devices by name
        return await Task.FromResult(filtered_devices.Where(d => 
            d.device_name.Contains(value, StringComparison.InvariantCultureIgnoreCase)).AsEnumerable());
    }

    private async Task Load_Filtered_Devices()
    {
        loading_devices = true;
        filtered_devices.Clear();
        
        try
        {
            MySqlConnection conn = new MySqlConnection(Configuration.MySQL.Connection_String);
            await conn.OpenAsync();

            string query;
            MySqlCommand cmd;

            // Build query based on selection
            if (!String.IsNullOrEmpty(selected_group))
            {
                // Filter by tenant, location, and group
                query = @"
                    SELECT id, device_name, access_key, tenant_name, location_name, group_name
                    FROM devices
                    WHERE authorized = 1 
                      AND tenant_name = @tenant_name 
                      AND location_name = @location_name
                      AND group_name = @group_name
                    ORDER BY device_name";
                
                cmd = new MySqlCommand(query, conn);
                cmd.Parameters.AddWithValue("@tenant_name", selected_tenant);
                cmd.Parameters.AddWithValue("@location_name", selected_location);
                cmd.Parameters.AddWithValue("@group_name", selected_group);
            }
            else
            {
                // Filter by tenant and location only
                query = @"
                    SELECT id, device_name, access_key, tenant_name, location_name, group_name
                    FROM devices
                    WHERE authorized = 1 
                      AND tenant_name = @tenant_name 
                      AND location_name = @location_name
                    ORDER BY device_name";
                
                cmd = new MySqlCommand(query, conn);
                cmd.Parameters.AddWithValue("@tenant_name", selected_tenant);
                cmd.Parameters.AddWithValue("@location_name", selected_location);
            }

            using (DbDataReader reader = await cmd.ExecuteReaderAsync())
            {
                while (await reader.ReadAsync())
                {
                    filtered_devices.Add(new DeviceInfo
                    {
                        device_id = reader["id"].ToString(),
                        device_name = reader["device_name"].ToString(),
                        access_key = reader["access_key"].ToString(),
                        tenant_name = reader["tenant_name"].ToString() ?? "N/A",
                        location_name = reader["location_name"].ToString() ?? "N/A",
                        group_name = reader["group_name"].ToString() ?? "",
                        online = false
                    });
                }
            }

            await conn.CloseAsync();
        }
        catch (Exception ex)
        {
            Logging.Handler.Error("Relay_Manager_Dialog -> Load_Filtered_Devices", "Error", ex.ToString());
            error_message = $"Failed to load devices: {ex.Message}";
        }
        finally
        {
            loading_devices = false;
            StateHasChanged();
        }
    }

    private async Task Create_Relay_Session()
    {
        if (selected_device == null)
        {
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
            Snackbar.Add("Please select a target device", Severity.Warning);
            return;
        }

        creating_session = true;
        error_message = String.Empty;
        StateHasChanged();

        try
        {
            var requestData = new
            {
                target_device_id = selected_device.access_key,
                target_port = target_port,
                protocol = protocol,
                is_persistent = Convert.ToBoolean(is_persistent ? 1 : 0),
            };

            var json = JsonSerializer.Serialize(requestData);
            
            string url = Configuration.Remote_Server.Connection_String + "/admin/relay/create";
            var responseJson = await Classes.Helper.Http.POST_Request_Json_With_Api_Key(url, json, false);

            if (string.IsNullOrEmpty(responseJson))
            {
                error_message = "Failed to create relay session - empty response";
                Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
                Snackbar.Add(error_message, Severity.Error);
                return;
            }

            var result = JsonSerializer.Deserialize<CreateRelayResponse>(responseJson, new JsonSerializerOptions 
            { 
                PropertyNameCaseInsensitive = true 
            });

            if (result?.success == true)
            {
                // If persistent, save to database
                if (is_persistent)
                {
                    await Save_Persistent_Session(result.session_id, selected_device.access_key);
                }
                
                Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
                Snackbar.Add($"Relay session created for {selected_device.device_name}!", Severity.Success);
                
                // Reset form but keep tenant/location/group selection
                selected_device = null;
                target_port = 3389;
                description = String.Empty;
                is_persistent = true;
                
                await Load_Active_Sessions(silent: false);
            }
            else
            {
                error_message = result?.error ?? "Failed to create relay session";
                Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
                Snackbar.Add(error_message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            error_message = $"Error: {ex.Message}";
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
            Snackbar.Add(error_message, Severity.Error);
            Logging.Handler.Error("Relay_Manager_Dialog -> Create_Relay_Session", "Error", ex.ToString());
        }
        finally
        {
            creating_session = false;
            StateHasChanged();
        }
    }

    private async Task Save_Persistent_Session(string sessionId, string accessKey)
    {
        try
        {
            // Get current username
            var user = (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;
            string username = user.FindFirst(ClaimTypes.Email)?.Value ?? "Unknown";

            MySqlConnection conn = new MySqlConnection(Configuration.MySQL.Connection_String);
            await conn.OpenAsync();

            // Get device id from access_key
            string deviceIdQuery = "SELECT id FROM devices WHERE access_key = @access_key LIMIT 1";
            MySqlCommand deviceIdCmd = new MySqlCommand(deviceIdQuery, conn);
            deviceIdCmd.Parameters.AddWithValue("@access_key", accessKey);

            object deviceIdResult = await deviceIdCmd.ExecuteScalarAsync();

            if (deviceIdResult == null)
            {
                Logging.Handler.Error("Relay_Manager_Dialog -> Save_Persistent_Session", "Error", $"Device with access_key {accessKey} not found");
                await conn.CloseAsync();
                return;
            }

            int deviceId = Convert.ToInt32(deviceIdResult);

            string query = @"
                INSERT INTO relay_sessions
                (enabled, session_id, target_device_id, target_port, protocol, created_at, created_by, description)
                VALUES
                (@enabled, @session_id, @target_device_id, @target_port, @protocol, @created_at, @created_by, @description)";

            MySqlCommand cmd = new MySqlCommand(query, conn);
            cmd.Parameters.AddWithValue("@enabled", 1);
            cmd.Parameters.AddWithValue("@session_id", sessionId);
            cmd.Parameters.AddWithValue("@target_device_id", deviceId);
            cmd.Parameters.AddWithValue("@target_port", target_port);
            cmd.Parameters.AddWithValue("@protocol", protocol);
            cmd.Parameters.AddWithValue("@created_at", DateTime.Now);
            cmd.Parameters.AddWithValue("@created_by", username);
            cmd.Parameters.AddWithValue("@description", description ?? "");

            await cmd.ExecuteNonQueryAsync();
            await conn.CloseAsync();

            Logging.Handler.Debug("Relay_Manager_Dialog -> Save_Persistent_Session", "Saved", $"Session {sessionId} saved to database with device_id {deviceId}");
        }
        catch (Exception ex)
        {
            Logging.Handler.Error("Relay_Manager_Dialog -> Save_Persistent_Session", "Error", ex.ToString());
            // Don't throw - session is still created on relay server, just not persisted
        }
    }

    private async Task Load_Active_Sessions(bool silent = false)
    {
        if (!silent)
        {
            loading_sessions = true;
            StateHasChanged();
        }
        
        error_message = String.Empty;

        try
        {
            string url = Configuration.Remote_Server.Connection_String + "/admin/relay/list";
            var responseJson = await Classes.Helper.Http.Get_Request_With_Api_Key(url, false);
            
            if (string.IsNullOrEmpty(responseJson))
            {
                if (!silent)
                    error_message = "Failed to load active sessions - empty response";
                return;
            }

            var result = JsonSerializer.Deserialize<ListRelayResponse>(responseJson, new JsonSerializerOptions 
            { 
                PropertyNameCaseInsensitive = true 
            });

            if (result?.success == true)
            {
                active_sessions = result.sessions ?? new List<RelaySessionInfo>();
                
                // Backend liefert bereits alle nötigen Informationen
                // (target_device_name, tenant_name, location_name, group_name)
                // Keine zusätzliche DB-Abfrage mehr nötig!
                
                foreach (var session in active_sessions)
                {
                    Logging.Handler.Debug("Relay_Manager_Dialog -> Load_Active_Sessions",
                        $"Session {session.session_id}",
                        $"Device: {session.target_device_name ?? "N/A"}, Tenant: {session.tenant_name ?? "N/A"}, Persistent: {session.is_persistent}, Enabled: {session.enabled}");
                }
            }
            else
            {
                if (!silent)
                    error_message = result?.error ?? "Failed to load active sessions";
            }
        }
        catch (Exception ex)
        {
            if (!silent)
            {
                error_message = $"Error loading sessions: {ex.Message}";
                Logging.Handler.Error("Relay_Manager_Dialog -> Load_Active_Sessions", "Error", ex.ToString());
            }
        }
        finally
        {
            if (!silent)
            {
                loading_sessions = false;
                StateHasChanged();
            }
        }
    }

    private async Task Close_Relay_Session(string sessionId)
    {
        // Show confirmation dialog
        var options = new DialogOptions
        {
            CloseButton = true,
            FullWidth = true,
            MaxWidth = MaxWidth.Medium,
            BackgroundClass = "dialog-blurring",
        };

        bool? dialog_result = await DialogService.ShowMessageBox(
            "Warning", 
            "Are you sure you want to close this relay session? Active connections will be terminated.", 
            yesText: "Confirm", 
            cancelText: "Cancel", 
            options: options);

        bool state = Convert.ToBoolean(dialog_result == null ? "false" : "true");

        if (!state)
            return;

        try
        {
            string url = Configuration.Remote_Server.Connection_String + "/admin/relay/close?session_id=" + sessionId;
            var responseJson = await Classes.Helper.Http.POST_Request_With_Api_Key(url, false);

            if (string.IsNullOrEmpty(responseJson))
            {
                error_message = "Failed to close relay session - empty response";
                Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
                Snackbar.Add(error_message, Severity.Error);
                return;
            }

            var result = JsonSerializer.Deserialize<CloseRelayResponse>(responseJson, new JsonSerializerOptions 
            { 
                PropertyNameCaseInsensitive = true 
            });

            if (result?.success == true)
            {
                // Delete from database if persistent
                await Delete_Persistent_Session(sessionId);
                
                Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
                Snackbar.Add("Relay session closed successfully", Severity.Success);
                
                await Load_Active_Sessions(silent: false);
            }
            else
            {
                error_message = result?.error ?? "Failed to close relay session";
                Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
                Snackbar.Add(error_message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            error_message = $"Error closing session: {ex.Message}";
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
            Snackbar.Add(error_message, Severity.Error);
            Logging.Handler.Error("Relay_Manager_Dialog -> Close_Relay_Session", "Error", ex.ToString());
        }
    }

    private async Task Delete_Persistent_Session(string sessionId)
    {
        try
        {
            MySqlConnection conn = new MySqlConnection(Configuration.MySQL.Connection_String);
            await conn.OpenAsync();

            string query = "DELETE FROM relay_sessions WHERE session_id = @session_id";
            MySqlCommand cmd = new MySqlCommand(query, conn);
            cmd.Parameters.AddWithValue("@session_id", sessionId);

            await cmd.ExecuteNonQueryAsync();
            await conn.CloseAsync();

            Logging.Handler.Debug("Relay_Manager_Dialog -> Delete_Persistent_Session", "Deleted", $"Session {sessionId} deleted from database");
        }
        catch (Exception ex)
        {
            Logging.Handler.Error("Relay_Manager_Dialog -> Delete_Persistent_Session", "Error", ex.ToString());
            // Don't throw - session is closed on relay server anyway
        }
    }

    private async Task Toggle_Session_Enabled(RelaySessionInfo session, bool enabled)
    {
        try
        {
            int enabledInt = enabled ? 1 : 0;
            
            Logging.Handler.Debug("Relay_Manager_Dialog -> Toggle_Session_Enabled", 
                $"Session {session.session_id}", 
                $"Setting enabled to {enabledInt}");

            // Optimistically update the UI immediately
            bool oldValue = session.enabled;
            session.enabled = enabled;
            StateHasChanged();

            MySqlConnection conn = new MySqlConnection(Configuration.MySQL.Connection_String);
            await conn.OpenAsync();

            string query = "UPDATE relay_sessions SET enabled = @enabled WHERE session_id = @session_id";
            MySqlCommand cmd = new MySqlCommand(query, conn);
            cmd.Parameters.AddWithValue("@enabled", enabledInt);
            cmd.Parameters.AddWithValue("@session_id", session.session_id);

            int rowsAffected = await cmd.ExecuteNonQueryAsync();
            await conn.CloseAsync();

            if (rowsAffected > 0)
            {
                Logging.Handler.Debug("Relay_Manager_Dialog -> Toggle_Session_Enabled", 
                    $"Session {session.session_id}", 
                    $"Successfully updated to enabled={enabledInt}");
                
                Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
                Snackbar.Add($"Session {(enabled ? "enabled" : "disabled")} successfully", Severity.Success);
            }
            else
            {
                // Rollback on failure
                session.enabled = oldValue;
                StateHasChanged();
                
                Logging.Handler.Error("Relay_Manager_Dialog -> Toggle_Session_Enabled", 
                    $"Session {session.session_id}", 
                    "No rows affected - session not found in DB");
                
                Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
                Snackbar.Add("Session not found in database", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            // Rollback on error
            session.enabled = !session.enabled;
            StateHasChanged();
            
            Logging.Handler.Error("Relay_Manager_Dialog -> Toggle_Session_Enabled", "Error", ex.ToString());
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
            Snackbar.Add($"Failed to toggle session state: {ex.Message}", Severity.Error);
        }
    }

